# Copy this file to .env and fill in your values
# Never commit .env to source control

# PostgreSQL connection string
DATABASE_URL=postgresql://desert:desert@localhost:5432/desert_dev

# Redis connection string
REDIS_URL=redis://:devpassword@localhost:6379

# API server port
PORT=3001

# Cloudflare R2 storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=litro-photos-production

# Monthly Claude API spend threshold that fires a Slack alert (default $50).
# Alert posts to SLACK_WEBHOOK_URL; no-op when that is unset.
COST_ALERT_THRESHOLD_USD=50

# SuperTokens auth
SUPERTOKENS_CONNECTION_URI=https://your-app.aws.supertokens.io:3568
SUPERTOKENS_API_KEY=your-supertokens-api-key

# Public URLs (used by SuperTokens appInfo)
API_URL=http://localhost:3000
WEB_URL=http://localhost:3001

# Google OAuth (for Google Sign-In — Story 1.2)
# Create credentials at https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=xxxx.apps.googleusercontent.com

# Apple Sign-In (for token audience verification — Story 1.3)
APPLE_APP_BUNDLE_ID=com.desert.app

# Email (Resend — used for data export notifications)
RESEND_API_KEY=re_your_resend_api_key

# Feedback webhook (Slack Incoming Webhook URL — optional, feedback logged if not set)
FEEDBACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# DLQ Slack alert webhook (optional — logs warning if not set)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Admin dashboard URL (included in DLQ Slack alerts — optional)
ADMIN_DASHBOARD_URL=

# Google Places API (for station sync — Story 2.1)
# Create API key at https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Anthropic Claude API (logo recognition — Story 3.6; OCR switched to Gemini in Story 3.13)
# Get key at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Google Gemini API (OCR price extraction — Story 3.13)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# OCR pipeline cost controls (Story 3.9)
# Max OCR jobs processed per minute (default: 60)
OCR_WORKER_RATE_LIMIT_PER_MINUTE=60
# Daily Gemini API spend cap in USD — worker pauses when exceeded (default: $20)
MAX_DAILY_OCR_SPEND_USD=20

# How many days to keep photos for rejected submissions before cleanup worker deletes them.
# Gives ops a window to recover photos from short-lived failures (no_station_match, OCR miss).
# shadow_rejected photos are always kept 30 days for admin review. (default: 2)
REJECTED_PHOTO_RETENTION_DAYS=2

# Node environment
NODE_ENV=development

# Copy this file to .env and fill in your values
# Never commit .env to source control

# PostgreSQL connection string
DATABASE_URL=postgresql://desert:desert@localhost:5432/desert_dev

# Redis connection string
REDIS_URL=redis://localhost:6379

# API server port
PORT=3001

# Cloudflare R2 storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=desert-photos

# SuperTokens auth
SUPERTOKENS_CONNECTION_URI=https://your-app.aws.supertokens.io:3568
SUPERTOKENS_API_KEY=your-supertokens-api-key

# Public URLs (used by SuperTokens appInfo)
API_URL=http://localhost:3000
WEB_URL=http://localhost:3001

# Node environment
NODE_ENV=development

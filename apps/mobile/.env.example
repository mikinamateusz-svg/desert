# Copy this file to .env and fill in your values
# Never commit .env to source control
# Expo reads EXPO_PUBLIC_* variables at build time

# API base URL
EXPO_PUBLIC_API_URL=http://localhost:3001

# Google OAuth client IDs (for Google Sign-In — Story 1.2)
# Create credentials at https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxx.apps.googleusercontent.com

{
  "expo": {
    "name": "Litro",
    "slug": "desert",
    "owner": "mmikina",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "desert",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.litro.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSUserNotificationUsageDescription": "We'll alert you when fuel prices drop near you.",
        "NSLocationWhenInUseUsageDescription": "Litro uses your location to find fuel stations near you and show local prices."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "package": "com.litro.app",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "@rnmapbox/maps",
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#f59e0b",
          "sounds": [],
          "androidMode": "default"
        }
      ],
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Litro to access your camera to photograph fuel station price boards."
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "945d66cd-fcc2-46ab-b9fa-076804320497"
      }
    }
  }
}

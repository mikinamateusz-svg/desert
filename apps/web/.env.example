# Internal NestJS API URL — server-side only, never exposed to browsers (no NEXT_PUBLIC_ prefix)
# Dev: NestJS runs on port 3000 by default
# Prod: set to Railway API service URL (e.g. https://api-production-xxxx.up.railway.app)
INTERNAL_API_URL=http://localhost:3000

# Mapbox public token — safe to expose in client-side code (starts with pk.)
# Get yours at https://account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-token-here

{
  "name": "desert",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --filter=!@desert/mobile",
    "dev:mobile": "turbo run dev --filter=@desert/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "2.8.20",
    "typescript": "^5.8.3",
    "prettier": "^3.5.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "~18.3.12"
    }
  }
}

    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.2.0",
    "@prisma/client": "7.2.0",
    "pg": "^8.14.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "prisma": "7.2.0",
    "typescript": "^5.8.3"
  }
